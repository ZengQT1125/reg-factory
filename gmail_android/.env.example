# Gmail Android registration local environment
# Copy to .env and fill only the values you need. Real process environment variables win over .env.

# Appium / Android
APPIUM_SERVER=http://127.0.0.1:4723
ANDROID_DEVICE=127.0.0.1:5675
ADB_PATH=

# Optional account generation
GMAIL_USERNAME_PREFIX=

# Phone verification mode
# manual: stop at phone verification and let the operator finish it.
# provider: reserved for a compliant internal SMS provider integration; not enabled by default.
PHONE_VERIFICATION_MODE=manual

# SMS provider placeholders, modeled after reg-factory/common/sms.py.
# Keep secrets in .env or system env only. Do not commit real values.
SMS_API_BASE=http://www.firefox.fun/yhapi.ashx
SMS_TOKEN=
SMS_PROJECT_ID_GMAIL=
SMS_MAXPRICE_GMAIL=20
SMS_COUNTRY_BLACKLIST_GMAIL=261,63

HERO_SMS_API_BASE=https://hero-sms.com/stubs/handler_api.php
HERO_SMS_API_KEY=
HERO_SMS_SERVICE_GMAIL=

# Consent gates
# Do not enable in unattended runs unless the user/operator has explicitly agreed to the relevant terms.
ACCEPT_TERMS=0
